/* Estilos Generales */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}
body {
    font-family: 'Arial', sans-serif;
    background-color: #0b0f19;
    color: #ffffff;
    line-height: 1.6;
}
header {
    background: linear-gradient(135deg, #1e293b, #0f172a);
    padding: 20px;
    text-align: center;
    border-bottom: 2px solid #38bdf8;
}
h1 {
    color: #38bdf8;
    font-size: 24px;
    letter-spacing: 1px;
}
/* Contenedor Principal */
main {
    padding: 20px;
    max-width: 800px;
    margin: 0 auto;
}
.card {
    background: #1e293b;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    border-left: 4px solid #38bdf8;
}
h2 {
    color: #f8fafc;
    margin-bottom: 10px;
    font-size: 18px;
}
p {
    color: #94a3b8;
    font-size: 14px;
}
/* Botón Interactivo */
.btn-container {
    text-align: center;
    margin-top: 30px;
}
button {
    background: #38bdf8;
    color: #0f172a;
    border: none;
    padding: 12px 24px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 25px;
    cursor: pointer;
    transition: background 0.3s ease;
}
button:hover {
    background: #0ea5e9;
}
